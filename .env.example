# ============================================================================
# PayPerTool — environment variables
# Copy to .env (local dev) and set the same values in Railway dashboard for prod.
# ============================================================================

# --- Required ---

# Postgres connection string. Locally: postgres://user:pass@localhost:5432/paypertool
# Production: Railway provisions one automatically when you add a Postgres plugin
# and exposes it as DATABASE_URL.
DATABASE_URL=postgres://user:pass@localhost:5432/paypertool

# Random 32+ char string. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_me_with_openssl_rand_hex_32

# Network for x402 settlement. Use "base-sepolia" for testing (free testnet
# USDC), "base" for production (real money on Base mainnet).
X402_NETWORK=base

# Port the api-server listens on. Railway sets this automatically.
PORT=8080

# --- Optional ---

# OpenAI-compatible LLM key (used by `summarize_url` and `extract_facts` tools).
# Without it, those two tools return 503. Other 10 tools work fine.
# OPENAI_API_KEY=sk-...

# GitHub personal access token (used by `gh_repo_summary` for higher rate limits).
# Without it the tool falls back to unauthenticated GitHub API (60 req/h shared).
# GH_TOKEN=ghp_...
